APP_NAME=brakerscalp
ENVIRONMENT=dev
LOG_LEVEL=INFO
TIMEZONE=Asia/Hochiminh

# Telegram
BOT_TOKEN=replace-me
BOT_PARSE_MODE=HTML
BOT_DISABLE_LINK_PREVIEW=true
BOT_POLLING_TIMEOUT_SECONDS=30
BOT_STARTUP_NOTIFICATIONS=true
BOT_SHUTDOWN_NOTIFICATIONS=false
ALLOWED_CHAT_IDS=[-1003788053657]
ALERT_CHAT_IDS=[-1003788053657]
ALERT_MESSAGE_THREAD_ID=475

# PostgreSQL
POSTGRES_DB=brakerscalp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=

# Exchange ingestion
ENABLE_BINANCE=true
ENABLE_BYBIT=true
ENABLE_OKX=true
EXCHANGE_REQUEST_TIMEOUT_SECONDS=10
EXCHANGE_BOOK_DEPTH=10
EXCHANGE_TRADES_LIMIT=50
HEALTHCHECK_SYMBOL=BTCUSDT

# Engine / scheduling
POLL_INTERVAL_SECONDS=30
ENGINE_INTERVAL_SECONDS=20
SIGNAL_DEDUPE_TTL_SECONDS=14400

# API / app
API_HOST=0.0.0.0
API_PORT=8080
UNIVERSE_PATH=config/universe.json

# Observability
ENABLE_GRAFANA=true
ENABLE_PROMETHEUS=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
SENTRY_DSN=
