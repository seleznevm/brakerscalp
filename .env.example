APP_NAME=brakerscalp
ENVIRONMENT=dev
LOG_LEVEL=INFO
TIMEZONE=Asia/Ho_Chi_Minh

# Telegram
BOT_TOKEN=replace-me
BOT_PARSE_MODE=HTML
BOT_DISABLE_LINK_PREVIEW=true
BOT_POLLING_TIMEOUT_SECONDS=30
BOT_STARTUP_NOTIFICATIONS=true
BOT_SHUTDOWN_NOTIFICATIONS=false
ALLOWED_CHAT_IDS=[-1003788053657]
ALERT_CHAT_IDS=[-1003788053657]
# Use /chatinfo inside the target group/topic to discover the correct message_thread_id.
ALERT_MESSAGE_THREAD_ID=474

# PostgreSQL
POSTGRES_DB=brakerscalp
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=admin
REDIS_COMMANDER_PORT=8081

# Exchange ingestion
ENABLE_BINANCE=true
ENABLE_BYBIT=true
ENABLE_OKX=true
EXCHANGE_REQUEST_TIMEOUT_SECONDS=10
EXCHANGE_BOOK_DEPTH=10
EXCHANGE_TRADES_LIMIT=50
HEALTHCHECK_SYMBOL=BTCUSDT

# Engine / scheduling
POLL_INTERVAL_SECONDS=30
COLLECTOR_SYMBOL_CONCURRENCY=6
ENGINE_INTERVAL_SECONDS=20
MINIMUM_ALERT_CONFIDENCE=65
SIGNAL_DEDUPE_TTL_SECONDS=14400
SIGNAL_DUPLICATE_WINDOW_MINUTES=180

# API / app
API_HOST=0.0.0.0
API_PORT=8080
UNIVERSE_PATH=config/universe.json

# Observability
ENABLE_GRAFANA=true
ENABLE_PROMETHEUS=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050
SENTRY_DSN=
